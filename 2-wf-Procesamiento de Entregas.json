    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n    e.IdEntrega,\n    e.IdEstudiante,\n    e.IdTarea,\n    e.FechaEntrega,\n    t.FechaLimite,\n    e.Estado\nFROM Entregas e\nINNER JOIN Tareas t\nON e.IdTarea = t.IdTarea\nWHERE e.Estado = 'RECIBIDA'",
        "options": {}
      },
