    },
    {
      "parameters": {
        "jsCode": "const entrega = new Date($json.FechaEntrega);\nconst limite = new Date($json.FechaLimite);\n\nlet estado = \"PENDIENTE_CALIFICACION\";\n\nif(entrega > limite){\n  estado = \"ENTREGA_TARDIA\";\n}\n\nreturn [{\n  ...$json,\n  NuevoEstado: estado\n}];"
      },
      "type": "n8n-nodes-base.code",
